    "7種の環境音は、それぞれ単独でも、組み合わせても再生できます。バイノーラルビートやモジュラーシンセと重ねることも可能です。" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "The seven ambient sounds can play alone or combined, and can be layered over binaural beats or the modular synth."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The seven ambient sounds can play alone or combined, and can be layered over binaural beats or the modular synth."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los siete sonidos ambientales pueden sonar solos o combinados, y superponerse a los sonidos binaurales o al sintetizador modular."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "The seven ambient sounds can play alone or combined, and can be layered over binaural beats or the modular synth."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "The seven ambient sounds can play alone or combined, and can be layered over binaural beats or the modular synth."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os sete sons ambientes podem tocar sozinhos ou combinados e sobrepor-se aos batimentos binaurais ou ao sintetizador modular."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "The seven ambient sounds can play alone or combined, and can be layered over binaural beats or the modular synth."
